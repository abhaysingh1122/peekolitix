# ============================================
# EXAMPLE ENV FILE - COPY AND RENAME TO .env.local
# ============================================
# This shows you what to put in .env.local

# Step 1: Go to Supabase.com
# Step 2: Log in to your project
# Step 3: Settings (gear icon) → API
# Step 4: Copy the URL and paste below:
REACT_APP_SUPABASE_URL=https://your-project-id.supabase.co

# Step 5: On same page, copy "anon public" key and paste below:
REACT_APP_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6...

# NVIDIA API KEY (already provided - don't change!)
REACT_APP_NVIDIA_API_KEY=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

